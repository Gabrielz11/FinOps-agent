# Copie este arquivo para .env e ajuste se quiser sobrescrever os defaults.
# As CREDENCIAIS da AWS não ficam aqui — configure-as com `aws configure`
# (elas vão para ~/.aws/, fora do projeto).

# Região AWS (default no código: us-east-1)
FINOPS_REGION=

# Modelo Bedrock (confirme o id habilitado na sua conta em Bedrock > Model access)
FINOPS_MODEL_ID=

# Teto de passos do agente por requisição (guardrail de custo)
FINOPS_MAX_ITERATIONS=8